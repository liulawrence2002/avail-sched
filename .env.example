# Goblin Scheduler — example environment variables.
#
# Copy this file to `.env` at the repo root and fill in real values if you need to override the
# development defaults. docker-compose.yml loads the file automatically. The backend will NOT
# fall back to these defaults in a prod deploy (see application.yml Phase 1.6 hardening), so
# production environments must export these values explicitly.

# --- Database (used by both the Postgres container and the Spring Boot app) ---
POSTGRES_DB=goblin_sched
POSTGRES_USER=goblin
POSTGRES_PASSWORD=goblin
POSTGRES_PORT=5432

# --- Backend (Spring Boot) ---
# Only required when SPRING_PROFILES_ACTIVE is not "dev". In dev, application-dev.yml provides
# localhost defaults. Leaving these unset in a prod-profile run is a deliberate fail-fast.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/goblin_sched
SPRING_DATASOURCE_USERNAME=goblin
SPRING_DATASOURCE_PASSWORD=goblin
# SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080
PORT=8080

# CORS: comma-separated origins the /api/** endpoints accept.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173

# Base URL used when building shareable links (host link, participant link).
APP_BASE_URL=http://localhost:3001

# --- Frontend (Vite build args) ---
# Injected via Vite at build time; baked into the dist/ bundle.
VITE_API_BASE_URL=/api
# Optional dev-mode proxy target when running `npm run dev` outside docker-compose.
VITE_DEV_PROXY_TARGET=http://localhost:8080
